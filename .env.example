# =============================================================================
# .env.example — Data Pipeline Project
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# AZURE SQL — Source DB (OLTP)
# From: portal.azure.com → SQL Database → cmia-source-db → Connection strings
# -----------------------------------------------------------------------------
AZURE_SQL_SERVER=cmia-source-server.database.windows.net
AZURE_SQL_DATABASE=cmia-source-db
AZURE_SQL_USERNAME=your_admin_username
AZURE_SQL_PASSWORD=your_admin_password
AZURE_SQL_DRIVER={ODBC Driver 18 for SQL Server}

# Full connection string (alternative to individual fields above)
# AZURE_SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:cmia-source-server.database.windows.net,1433;Database=cmia-source-db;Uid=your_admin_username;Pwd=your_admin_password;Encrypt=yes;TrustServerCertificate=no;

# -----------------------------------------------------------------------------
# SNOWFLAKE — Target DW (OLAP)
# From: your Snowflake account URL and signup credentials
# Account identifier format: xxxxxxx-xxxxxxx (find in: Admin → Accounts)
# -----------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=CMIA_DW
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=CMIA_ETL_WH
SNOWFLAKE_ROLE=CMIA_ETL

# -----------------------------------------------------------------------------
# AWS RDS POSTGRESQL — Part 2 Target (OLTP)
# From: AWS Console → RDS → cmia-target-db → Connectivity & security → Endpoint
# -----------------------------------------------------------------------------
RDS_HOST=cmia-target-db.xxxxxxxxxx.us-east-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=cmia_target_db
RDS_USERNAME=your_master_username
RDS_PASSWORD=your_master_password

# -----------------------------------------------------------------------------
# AWS CREDENTIALS (for boto3 / AWS SDK access if needed)
# From: AWS Console → IAM → Your user → Security credentials
# Or run: aws configure
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# -----------------------------------------------------------------------------
# AZURE AKS — Kubernetes Deployment
# From: portal.azure.com → Kubernetes services → cmia-aks → Overview
# Resource group: cmia-source-db, Cluster: cmia-aks
# -----------------------------------------------------------------------------
AKS_RESOURCE_GROUP=cmia-source-db
AKS_CLUSTER_NAME=cmia-aks
AKS_REGION=centralus

# -----------------------------------------------------------------------------
# AZURE CONTAINER REGISTRY (ACR) — stores Docker images for AKS
# Create at: portal.azure.com → Container registries → Create
# Name must be globally unique, e.g. cmiaregistry
# -----------------------------------------------------------------------------
ACR_NAME=cmiaregistry
ACR_LOGIN_SERVER=cmiaregistry.azurecr.io

# -----------------------------------------------------------------------------
# APP SETTINGS
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
